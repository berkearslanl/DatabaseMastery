@model List<ResultCampaignDto>
@{
    ViewData["Title"] = "Kampanya Yönetimi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --accent:      #e6a03c;
        --accent-dark: #c8861e;
        --accent-soft: rgba(230,160,60,0.10);
        --green:       #22c55e;
        --green-soft:  rgba(34,197,94,0.12);
        --red:         #ef4444;
        --red-soft:    rgba(239,68,68,0.12);
        --purple:      #8b5cf6;
        --purple-soft: rgba(139,92,246,0.12);
        --border:      #eeebe5;
        --cr:          16px;
        --tr:          all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

    .pg-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:26px; flex-wrap:wrap; }
    .pg-title { font-family:'Playfair Display',serif; font-size:23px; font-weight:700; color:#1a1a1a; margin:0 0 4px; line-height:1.2; }
    .pg-desc { font-size:13px; color:#999; margin:0; }
    .btn-add { display:inline-flex; align-items:center; gap:8px; background:linear-gradient(135deg,var(--accent),var(--accent-dark)); color:#fff; border:none; padding:11px 22px; border-radius:12px; font-size:13.5px; font-weight:600; text-decoration:none; transition:var(--tr); box-shadow:0 4px 16px rgba(230,160,60,0.30); white-space:nowrap; flex-shrink:0; }
    .btn-add:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(230,160,60,0.40); color:#fff; }

    .stats-row { display:flex; gap:10px; margin-bottom:22px; flex-wrap:wrap; }
    .s-pill { display:inline-flex; align-items:center; gap:8px; background:#fff; border:1px solid var(--border); border-radius:30px; padding:6px 14px 6px 8px; font-size:13px; font-weight:500; color:#555; box-shadow:0 1px 5px rgba(0,0,0,0.04); }
    .s-pill .p-icon { width:26px; height:26px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; }
    .s-pill .p-num { font-size:14px; font-weight:700; color:#1a1a1a; }

    .toolbar { display:flex; align-items:center; gap:10px; margin-bottom:20px; flex-wrap:wrap; }
    .search-wrap { position:relative; flex:1; min-width:200px; max-width:340px; }
    .search-wrap .si { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#bbb; font-size:15px; pointer-events:none; }
    .search-input { width:100%; padding:10px 12px 10px 38px; border:1px solid var(--border); border-radius:11px; font-size:13.5px; font-family:'DM Sans',sans-serif; background:#fff; color:#1a1a1a; outline:none; transition:var(--tr); box-shadow:0 1px 4px rgba(0,0,0,0.04); }
    .search-input:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(230,160,60,0.13); }
    .filter-select { padding:10px 14px; border:1px solid var(--border); border-radius:11px; font-size:13px; font-family:'DM Sans',sans-serif; background:#fff; color:#555; outline:none; cursor:pointer; transition:var(--tr); box-shadow:0 1px 4px rgba(0,0,0,0.04); }
    .filter-select:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(230,160,60,0.13); }

    /* TABLE */
    .camp-table { width:100%; border-collapse:separate; border-spacing:0; background:#fff; border:1px solid var(--border); border-radius:var(--cr); overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.05); }
    .camp-table thead th { padding:14px 18px; font-size:12px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:0.05em; background:#faf8f5; border-bottom:1px solid var(--border); text-align:left; }
    .camp-table tbody tr { transition:var(--tr); animation:cardIn 0.38s ease both; }
    .camp-table tbody tr:hover { background:#fdfaf5; }
    .camp-table tbody td { padding:14px 18px; font-size:13.5px; color:#333; border-bottom:1px solid #f5f2ee; vertical-align:middle; }
    .camp-table tbody tr:last-child td { border-bottom:none; }

    .camp-title { font-weight:700; color:#1a1a1a; }
    .camp-desc { font-size:12px; color:#999; margin-top:2px; max-width:260px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    .badge-discount { display:inline-flex; align-items:center; gap:4px; background:var(--accent-soft); color:var(--accent-dark); font-size:12px; font-weight:700; padding:4px 10px; border-radius:20px; }
    .badge-status { display:inline-flex; align-items:center; gap:5px; padding:4px 10px; border-radius:20px; font-size:11.5px; font-weight:700; }
    .badge-status.active { background:var(--green-soft); color:#15803d; }
    .badge-status.passive { background:var(--red-soft); color:#b91c1c; }
    .badge-status.expired { background:rgba(107,100,96,0.10); color:#6b6460; }
    .s-dot { width:6px; height:6px; border-radius:50%; }
    .badge-status.active .s-dot { background:var(--green); animation:pulse 2s infinite; }
    .badge-status.passive .s-dot { background:var(--red); }
    .badge-status.expired .s-dot { background:#999; }

    .date-range { font-size:12px; color:#777; }

    .c-acts { display:flex; gap:6px; }
    .btn-act { display:inline-flex; align-items:center; justify-content:center; width:33px; height:33px; border-radius:9px; border:1px solid transparent; font-size:14px; cursor:pointer; text-decoration:none; transition:var(--tr); position:relative; }
    .btn-act.edit { background:#fff7ed; color:var(--accent-dark); border-color:#fde8c0; }
    .btn-act.edit:hover { background:var(--accent); color:#fff; border-color:var(--accent); transform:scale(1.12); box-shadow:0 3px 10px rgba(230,160,60,0.38); }
    .btn-act.delete { background:#fff5f5; color:var(--red); border-color:#fecaca; }
    .btn-act.delete:hover { background:var(--red); color:#fff; border-color:var(--red); transform:scale(1.12); box-shadow:0 3px 10px rgba(239,68,68,0.35); }
    .btn-act::after { content:attr(data-tip); position:absolute; bottom:calc(100% + 7px); left:50%; transform:translateX(-50%) scale(0.8); background:#1a1a1a; color:#fff; font-size:11px; font-weight:500; white-space:nowrap; padding:4px 9px; border-radius:6px; opacity:0; pointer-events:none; transition:all 0.15s ease; }
    .btn-act:hover::after { opacity:1; transform:translateX(-50%) scale(1); }

    .empty-state { padding:72px 24px; text-align:center; }
    .empty-icon { width:76px; height:76px; background:linear-gradient(135deg,#f9f7f4,#f0ebe2); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:30px; color:#ccc; margin:0 auto 20px; border:2px dashed #e0d9ce; }
    .empty-title { font-family:'Playfair Display',serif; font-size:17px; font-weight:700; color:#333; margin-bottom:6px; }
    .empty-desc { font-size:13.5px; color:#bbb; margin-bottom:22px; }

    .del-mc { border-radius:18px !important; border:1px solid #f0ede8 !important; overflow:hidden; box-shadow:0 24px 64px rgba(0,0,0,0.13) !important; }
    .del-mb { padding:36px 30px 22px; text-align:center; }
    .del-mt { font-family:'Playfair Display',serif; font-size:19px; font-weight:700; color:#1a1a1a; margin-bottom:8px; }
    .del-mf { padding:0 30px 28px; display:flex; gap:10px; }
    .btn-cancel { flex:1; border-radius:11px; border:1px solid #ebebeb; background:#fff; font-size:13.5px; font-weight:600; color:#555; padding:11px; cursor:pointer; transition:var(--tr); }
    .btn-cancel:hover { background:#f7f5f2; }
    .btn-del-ok { flex:1; border-radius:11px; background:var(--red); color:#fff; font-size:13.5px; font-weight:600; padding:11px; text-align:center; text-decoration:none; border:none; box-shadow:0 4px 14px rgba(239,68,68,0.28); display:flex; align-items:center; justify-content:center; gap:7px; transition:var(--tr); }
    .btn-del-ok:hover { background:#dc2626; color:#fff; box-shadow:0 6px 20px rgba(239,68,68,0.38); }

    @@keyframes cardIn { from { opacity:0; transform:translateY(14px) scale(0.97); } to { opacity:1; transform:translateY(0) scale(1); } }
    @@keyframes pulse { 0%,100% { box-shadow:0 0 0 2px rgba(34,197,94,0.25); } 50% { box-shadow:0 0 0 5px rgba(34,197,94,0.08); } }

    @@media (max-width:767.98px) {
        .camp-table thead { display:none; }
        .camp-table tbody tr { display:flex; flex-wrap:wrap; padding:14px; gap:8px; border-bottom:1px solid #f0ede8; }
        .camp-table tbody td { border:none; padding:0; }
        .camp-table tbody td:first-child { width:100%; }
    }
</style>

<div class="pg-header">
    <div>
        <h1 class="pg-title">
            <i class="bi bi-megaphone-fill me-2" style="color:var(--accent);font-size:20px;vertical-align:middle;"></i>
            Kampanya Yönetimi
        </h1>
        <p class="pg-desc">Kampanyalarınızı görüntüleyin, düzenleyin ve yönetin.</p>
    </div>
    <a href="/Campaign/CreateCampaign" class="btn-add">
        <i class="bi bi-plus-lg"></i>
        Yeni Kampanya Ekle
    </a>
</div>

@{
    var total = Model?.Count ?? 0;
    var active = Model?.Count(c => c.Status && c.EndDate.Date >= DateTime.UtcNow.Date) ?? 0;
    var passive = Model?.Count(c => !c.Status) ?? 0;
    var expired = total - active - passive;
}

<div class="stats-row">
    <div class="s-pill">
        <div class="p-icon" style="background:#f5f2ee;"><i class="bi bi-megaphone-fill" style="color:#aaa;"></i></div>
        <span>Toplam</span>
        <span class="p-num">@total</span>
    </div>
    <div class="s-pill">
        <div class="p-icon" style="background:var(--green-soft);"><i class="bi bi-check-circle-fill" style="color:var(--green);"></i></div>
        <span>Aktif</span>
        <span class="p-num" style="color:#16a34a;">@active</span>
    </div>
    <div class="s-pill">
        <div class="p-icon" style="background:var(--red-soft);"><i class="bi bi-x-circle-fill" style="color:var(--red);"></i></div>
        <span>Pasif</span>
        <span class="p-num" style="color:#dc2626;">@passive</span>
    </div>
    <div class="s-pill">
        <div class="p-icon" style="background:rgba(107,100,96,0.08);"><i class="bi bi-clock-fill" style="color:#999;"></i></div>
        <span>Süresi Dolmuş</span>
        <span class="p-num" style="color:#6b6460;">@expired</span>
    </div>
</div>

<div class="toolbar">
    <div class="search-wrap">
        <i class="bi bi-search si"></i>
        <input type="text" class="search-input" id="searchInput" placeholder="Kampanya ara..." oninput="filterRows()" />
    </div>
    <select class="filter-select" id="statusFilter" onchange="filterRows()">
        <option value="all">Tüm Durumlar</option>
        <option value="active">Aktif</option>
        <option value="passive">Pasif</option>
        <option value="expired">Süresi Dolmuş</option>
    </select>
</div>

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-megaphone"></i></div>
        <div class="empty-title">Henüz kampanya eklenmemiş</div>
        <p class="empty-desc">Müşterilerinize özel indirimler oluşturmak için ilk kampanyanızı ekleyin.</p>
        <a href="/Campaign/CreateCampaign" class="btn-add" style="display:inline-flex;">
            <i class="bi bi-plus-lg"></i> Yeni Kampanya Ekle
        </a>
    </div>
}
else
{
    <table class="camp-table" id="campTable">
        <thead>
            <tr>
                <th>#</th>
                <th>Kampanya</th>
                <th>İndirim</th>
                <th>Tarih Aralığı</th>
                <th>Durum</th>
                <th style="text-align:center;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var c = Model[i];
                var isActive = c.Status && c.EndDate.Date >= DateTime.UtcNow.Date && c.StartDate.Date <= DateTime.UtcNow.Date;
                var isExpired = c.Status && c.EndDate.Date < DateTime.UtcNow.Date;
                var statusClass = isActive ? "active" : (isExpired ? "expired" : "passive");
                var statusText = isActive ? "Aktif" : (isExpired ? "Süresi Dolmuş" : "Pasif");
                var delay = i * 45;

                <tr data-name="@c.Title.ToLower()" data-status="@statusClass" style="animation-delay:@(delay)ms;">
                    <td><span style="font-size:12px;color:#bbb;font-weight:600;">#@c.CampaignId</span></td>
                    <td>
                        <div class="camp-title">@c.Title</div>
                        <div class="camp-desc" title="@c.Description">@c.Description</div>
                    </td>
                    <td><span class="badge-discount"><i class="bi bi-percent"></i> %@c.DiscountPercentage</span></td>
                    <td>
                        <div class="date-range">
                            <i class="bi bi-calendar3 me-1"></i>
                            @c.StartDate.ToString("dd MMM yyyy") — @c.EndDate.ToString("dd MMM yyyy")
                        </div>
                    </td>
                    <td>
                        <span class="badge-status @statusClass">
                            <span class="s-dot"></span> @statusText
                        </span>
                    </td>
                    <td>
                        <div class="c-acts" style="justify-content:center;">
                            <a href="/Campaign/UpdateCampaign/@c.CampaignId" class="btn-act edit" data-tip="Düzenle">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <button class="btn-act delete" data-tip="Sil" onclick="confirmDelete(@c.CampaignId, '@c.Title')">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content del-mc">
            <div class="del-mb">
                <div style="width:64px;height:64px;background:#fff5f5;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-size:26px;color:#ef4444;border:1.5px solid #fecaca;">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <div class="del-mt">Kampanya Silinsin mi?</div>
                <p style="font-size:13.5px;color:#888;margin-bottom:4px;">
                    <strong id="delName" style="color:#333;"></strong> adlı kampanya kalıcı olarak silinecek.
                </p>
                <p style="font-size:12px;color:#ccc;margin-bottom:0;">Bu işlem geri alınamaz.</p>
            </div>
            <div class="del-mf">
                <button class="btn-cancel" data-bs-dismiss="modal">Vazgeç</button>
                <a id="delLink" href="#" class="btn-del-ok">
                    <i class="bi bi-trash3-fill"></i> Evet, Sil
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterRows() {
        var q = document.getElementById('searchInput').value.toLowerCase().trim();
        var st = document.getElementById('statusFilter').value;
        document.querySelectorAll('#campTable tbody tr').forEach(function(r) {
            var nm = (r.dataset.name || '').includes(q);
            var sm = st === 'all' || r.dataset.status === st;
            r.style.display = (nm && sm) ? '' : 'none';
        });
    }

    function confirmDelete(id, name) {
        document.getElementById('delName').textContent = name;
        document.getElementById('delLink').href = '/Campaign/DeleteCampaign/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
}
