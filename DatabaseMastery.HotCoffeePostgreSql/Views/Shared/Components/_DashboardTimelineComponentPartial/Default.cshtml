@model List<ActivityLog>
<div class="col-xl-4">
    <div class="dash-card h-100">
        <div class="dash-card-header">
            <div>
                <div class="section-title">Günlük Aktiviteler</div>
                <div class="section-sub">Son gerçekleşen işlemler</div>
            </div>
            <span style="font-size:11px;background:var(--green-soft);color:#16a34a;padding:3px 9px;border-radius:20px;font-weight:700;">
                <i class="bi bi-circle-fill" style="font-size:7px;animation:pulse-g 2s infinite;"></i> Canlı
            </span>
        </div>
        <div class="dash-card-body pt-0">
            <div class="timeline">
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <div class="tl-item">
                            <div class="tl-icon" style="background:@item.IconBackground;">
                                <i class="@item.Icon" style="color:@item.IconColor;"></i>
                            </div>
                            <div class="tl-content">
                                <div class="tl-title">@item.Title</div>
                                <div class="tl-desc">@item.Description</div>
                                <div class="tl-time">@GetTimeAgo(item.CreatedAt)</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted text-center py-3">Henüz aktivite yok</p>
                }
            </div>
        </div>
    </div>
</div>
@functions {
    string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "Az önce";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} dakika önce";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} saat önce";
        return $"{(int)diff.TotalDays} gün önce";
    }
}