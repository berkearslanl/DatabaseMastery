@{
    int approvalRate = ViewBag.ApprovalRate;
    int cancelRate = ViewBag.CancelRate;
    int satisfactionRate = ViewBag.SatisfactionRate;
    int densityRate = ViewBag.DensityRate;
    int thisWeekTotal = ViewBag.ThisWeekTotal;
    int thisWeekGuests = ViewBag.ThisWeekGuests;
    int guestDiff = ViewBag.GuestDiff;
    int reservationDiff = ViewBag.ReservationDiff;
}

<div class="col-xl-4">
    <div class="dash-card h-100">
        <div class="dash-card-header">
            <div>
                <div class="section-title">Haftalık Özet</div>
                <div class="section-sub">Bu haftaki performans</div>
            </div>
        </div>
        <div class="dash-card-body">

            <div class="d-flex flex-column gap-3">

                <div>
                    <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                        <span style="font-weight:600;">Onay Oranı</span>
                        <span style="font-weight:700;color:#16a34a;">%@approvalRate</span>
                    </div>
                    <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                        <div style="width:@(approvalRate)%;height:100%;background:linear-gradient(90deg,var(--green),#16a34a);border-radius:6px;"></div>
                    </div>
                </div>

                <div>
                    <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                        <span style="font-weight:600;">Rez. Yoğunluğu</span>
                        <span style="font-weight:700;color:var(--accent-dark);">%@densityRate</span>
                    </div>
                    <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                        <div style="width:@(densityRate)%;height:100%;background:linear-gradient(90deg,var(--accent),var(--accent-dark));border-radius:6px;"></div>
                    </div>
                </div>

                <div>
                    <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                        <span style="font-weight:600;">Müşteri Memnuniyeti</span>
                        <span style="font-weight:700;color:var(--blue);">%@satisfactionRate</span>
                    </div>
                    <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                        <div style="width:@(satisfactionRate)%;height:100%;background:linear-gradient(90deg,var(--blue),#2563eb);border-radius:6px;"></div>
                    </div>
                </div>

                <div>
                    <div class="d-flex justify-content-between mb-1" style="font-size:12.5px;">
                        <span style="font-weight:600;">İptal Oranı</span>
                        <span style="font-weight:700;color:var(--red);">%@cancelRate</span>
                    </div>
                    <div style="background:#f0ede8;border-radius:6px;height:7px;overflow:hidden;">
                        <div style="width:@(cancelRate)%;height:100%;background:linear-gradient(90deg,var(--red),#dc2626);border-radius:6px;"></div>
                    </div>
                </div>

            </div>

            <hr style="border-color:var(--border);margin:18px 0;">

            <!-- Haftalık Özet -->
            <div style="background:linear-gradient(135deg,var(--accent-soft),rgba(230,160,60,0.05));border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;">
                <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;font-weight:700;margin-bottom:8px;">
                    <i class="bi bi-calendar-week" style="color:var(--accent);"></i> Bu Haftanın Özeti
                </div>
                <div class="d-flex justify-content-between align-items-end">
                    <div>
                        <div style="font-family:'Playfair Display',serif;font-size:28px;font-weight:800;color:var(--text);line-height:1;">
                            @thisWeekTotal
                        </div>
                        <div style="font-size:12px;color:var(--muted);margin-top:2px;">rezervasyon</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-family:'Playfair Display',serif;font-size:28px;font-weight:800;color:var(--accent-dark);line-height:1;">
                            @thisWeekGuests
                        </div>
                        <div style="font-size:12px;color:var(--muted);margin-top:2px;">misafir</div>
                    </div>
                </div>
                <div style="font-size:12px;color:var(--muted);margin-top:8px;">
                    Geçen haftaya göre
                    @if (reservationDiff >= 0)
                    {
                        <strong style="color:#16a34a;">+@reservationDiff rez.</strong>
                    }
                    else
                    {
                        <strong style="color:#dc2626;">@reservationDiff rez.</strong>
                    }
                    ,
                    @if (guestDiff >= 0)
                    {
                        <strong style="color:#16a34a;">+@guestDiff misafir</strong>
                    }
                    else
                    {
                        <strong style="color:#dc2626;">@guestDiff misafir</strong>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
