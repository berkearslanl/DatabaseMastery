<!-- METRIC TILES -->
<div class="metric-grid">
    <div class="metric-tile mt-amber">
        <div class="mt-icon"><i class="bi bi-calendar-day-fill" style="color:#c8861e;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.TodayReservation</div><div class="mt-lbl">Bugünkü Rez.</div></div>
    </div>
    <div class="metric-tile mt-sky">
        <div class="mt-icon"><i class="bi bi-calendar-week-fill" style="color:#2563eb;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.WeekReservation</div><div class="mt-lbl">Bu Haftaki Rez.</div></div>
    </div>
    <div class="metric-tile mt-sage">
        <div class="mt-icon"><i class="bi bi-calendar-month-fill" style="color:#16a34a;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.MonthReservation</div><div class="mt-lbl">Bu Ayki Rez.</div></div>
    </div>
    <div class="metric-tile mt-lemon">
        <div class="mt-icon"><i class="bi bi-eye-fill" style="color:#b45309;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.ActiveReview</div><div class="mt-lbl">Yayındaki Yorum</div></div>
    </div>
    <div class="metric-tile mt-rose">
        <div class="mt-icon"><i class="bi bi-eye-slash-fill" style="color:#dc2626;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.HiddenReview</div><div class="mt-lbl">Gizli Yorum</div></div>
    </div>
    <div class="metric-tile mt-mint">
        <div class="mt-icon"><i class="bi bi-basket3-fill" style="color:#0d9488;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.ActiveProduct</div><div class="mt-lbl">Aktif Ürün</div></div>
    </div>
    <div class="metric-tile mt-lavender">
        <div class="mt-icon"><i class="bi bi-tags-fill" style="color:#7c3aed;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.ActiveCategory</div><div class="mt-lbl">Aktif Kategori</div></div>
    </div>
    <div class="metric-tile mt-peach">
        <div class="mt-icon"><i class="bi bi-person-fill-check" style="color:#c2410c;font-size:17px;"></i></div>
        <div><div class="mt-num">@ViewBag.TotalCustomer</div><div class="mt-lbl">Toplam Müşteri</div></div>
    </div>
</div>
