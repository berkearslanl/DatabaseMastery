@model List<ResultCampaignDto>

@if (Model != null && Model.Any())
{
    <!-- Floating Campaign Button -->
    <button id="campFloatBtn" onclick="document.getElementById('campModal').classList.add('show')" style="
        position:fixed; bottom:28px; right:28px; z-index:999;
        background:linear-gradient(135deg,#e6a03c,#c8861e);
        color:#fff; border:none; padding:14px 22px; border-radius:50px;
        font-size:14px; font-weight:700; font-family:'Poppins',sans-serif;
        display:flex; align-items:center; gap:9px;
        box-shadow:0 6px 28px rgba(230,160,60,0.45);
        cursor:pointer; transition:all 0.22s cubic-bezier(0.4,0,0.2,1);
        animation:campBtnIn 0.5s 1s ease both;
    ">
        <i class="fa fa-bullhorn" style="font-size:16px;"></i>
        Bugünün Kampanyaları
        <span style="background:rgba(255,255,255,0.25);padding:2px 8px;border-radius:20px;font-size:12px;font-weight:800;">@Model.Count</span>
    </button>

    <!-- Campaign Modal Overlay -->
    <div id="campModal" style="
        display:none; position:fixed; inset:0; z-index:1050;
        background:rgba(0,0,0,0.5); backdrop-filter:blur(4px);
        align-items:center; justify-content:center; padding:20px;
    ">
        <div style="
            background:#fff; border-radius:20px; max-width:480px; width:100%;
            box-shadow:0 24px 64px rgba(0,0,0,0.18); overflow:hidden;
            animation:campModalIn 0.35s ease both; max-height:85vh; display:flex; flex-direction:column;
        ">
            <!-- Header -->
            <div style="padding:24px 24px 18px; border-bottom:1px solid #f0ede8; flex-shrink:0;">
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <div style="width:42px;height:42px;background:linear-gradient(135deg,rgba(230,160,60,0.15),rgba(230,160,60,0.08));border-radius:12px;display:flex;align-items:center;justify-content:center;">
                            <i class="fa fa-bullhorn" style="font-size:18px;color:#c8861e;"></i>
                        </div>
                        <div>
                            <div style="font-family:'Lora',serif;font-size:18px;font-weight:700;color:#1a1a1a;">Günün Kampanyaları</div>
                            <div style="font-size:12px;color:#999;">Sizin için özel fırsatlar</div>
                        </div>
                    </div>
                    <button onclick="document.getElementById('campModal').classList.remove('show')" style="
                        width:34px;height:34px;border-radius:10px;border:1px solid #eeebe5;background:#fff;
                        display:flex;align-items:center;justify-content:center;font-size:16px;color:#999;cursor:pointer;
                        transition:all 0.2s;
                    " onmouseover="this.style.background='#f5f2ee'" onmouseout="this.style.background='#fff'">
                        <i class="fa fa-times"></i>
                    </button>
                </div>
            </div>

            <!-- Campaign List -->
            <div style="padding:16px 24px 24px; overflow-y:auto; flex:1;">
                @for (int i = 0; i < Model.Count; i++)
                {
                    var c = Model[i];
                    var delay = i * 80;
                    <div style="
                        background:#fdfcfb; border:1px solid #f0ede8; border-radius:14px;
                        padding:18px; margin-bottom:12px;
                        transition:all 0.22s cubic-bezier(0.4,0,0.2,1);
                        animation:campItemIn 0.4s @(delay)ms ease both;
                    " onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.08)'"
                       onmouseout="this.style.transform='';this.style.boxShadow=''">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:10px;">
                            <div style="font-size:15px;font-weight:700;color:#1a1a1a;line-height:1.3;">@c.Title</div>
                            <span style="
                                background:linear-gradient(135deg,#e6a03c,#c8861e);color:#fff;
                                font-size:14px;font-weight:800;padding:5px 12px;border-radius:20px;
                                white-space:nowrap;flex-shrink:0;
                            ">%@c.DiscountPercentage</span>
                        </div>
                        <p style="font-size:13px;color:#777;margin:0 0 10px;line-height:1.5;">@c.Description</p>
                        <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:#bbb;">
                            <i class="fa fa-calendar"></i>
                            @c.StartDate.ToString("dd MMM") — @c.EndDate.ToString("dd MMM yyyy")
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <style>
        @@keyframes campBtnIn {
            from { opacity:0; transform:translateY(20px) scale(0.9); }
            to { opacity:1; transform:translateY(0) scale(1); }
        }
        @@keyframes campModalIn {
            from { opacity:0; transform:scale(0.92) translateY(20px); }
            to { opacity:1; transform:scale(1) translateY(0); }
        }
        @@keyframes campItemIn {
            from { opacity:0; transform:translateY(10px); }
            to { opacity:1; transform:translateY(0); }
        }
        #campFloatBtn:hover {
            transform:translateY(-3px) scale(1.03) !important;
            box-shadow:0 10px 36px rgba(230,160,60,0.55) !important;
        }
        #campModal.show { display:flex !important; }
    </style>

    <script>
        document.getElementById('campModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });
    </script>
}
