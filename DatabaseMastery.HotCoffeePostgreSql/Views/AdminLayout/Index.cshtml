    <!-- ═══ TOAST BİLDİRİM ═══ -->
    <div id="toastContainer" style="position:fixed;top:24px;right:24px;z-index:99999;display:flex;flex-direction:column;gap:10px;pointer-events:none;"></div>
    <style>
        .app-toast{pointer-events:all;display:flex;align-items:center;gap:12px;min-width:320px;max-width:440px;padding:14px 18px;border-radius:12px;background:#fff;border:1.5px solid #eeebe5;box-shadow:0 8px 32px rgba(0,0,0,0.12),0 2px 8px rgba(0,0,0,0.06);font-family:'DM Sans',sans-serif;transform:translateX(120%);opacity:0;transition:all .4s cubic-bezier(.4,0,.2,1)}
        .app-toast.show{transform:translateX(0);opacity:1}
        .app-toast.hide{transform:translateX(120%);opacity:0}
        .app-toast .t-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
        .app-toast .t-body{flex:1;min-width:0}
        .app-toast .t-title{font-size:13.5px;font-weight:700;color:#1a1a1a;margin-bottom:1px}
        .app-toast .t-msg{font-size:12px;color:#9a9590;line-height:1.4}
        .app-toast .t-close{background:none;border:none;font-size:16px;color:#ccc;cursor:pointer;padding:4px;border-radius:6px;transition:all .15s;flex-shrink:0}
        .app-toast .t-close:hover{color:#666;background:rgba(0,0,0,0.05)}
        .app-toast .t-progress{position:absolute;bottom:0;left:0;height:3px;border-radius:0 0 12px 12px;transition:width linear}
        .app-toast.t-success .t-icon{background:rgba(34,197,94,0.1);color:#16a34a}
        .app-toast.t-success .t-progress{background:#22c55e}
        .app-toast.t-success{border-color:rgba(34,197,94,0.2)}
        .app-toast.t-error .t-icon{background:rgba(239,68,68,0.1);color:#dc2626}
        .app-toast.t-error .t-progress{background:#ef4444}
        .app-toast.t-error{border-color:rgba(239,68,68,0.2)}
        .app-toast.t-warning .t-icon{background:rgba(245,158,11,0.1);color:#b45309}
        .app-toast.t-warning .t-progress{background:#f59e0b}
        .app-toast.t-warning{border-color:rgba(245,158,11,0.2)}
        .app-toast.t-info .t-icon{background:rgba(59,130,246,0.1);color:#2563eb}
        .app-toast.t-info .t-progress{background:#3b82f6}
        .app-toast.t-info{border-color:rgba(59,130,246,0.2)}
    </style>
    <script>
        function showToast(type, title, message, duration) {
            duration = duration || 4000;
            var icons = { success:'bi-check-circle-fill', error:'bi-x-circle-fill', warning:'bi-exclamation-triangle-fill', info:'bi-info-circle-fill' };
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'app-toast t-' + type;
            toast.style.position = 'relative';
            toast.style.overflow = 'hidden';
            toast.innerHTML =
                '<div class="t-icon"><i class="bi ' + (icons[type]||icons.info) + '"></i></div>' +
                '<div class="t-body"><div class="t-title">' + title + '</div><div class="t-msg">' + message + '</div></div>' +
                '<button class="t-close" onclick="this.parentElement.classList.replace(\'show\',\'hide\');setTimeout(()=>this.parentElement.remove(),400)"><i class="bi bi-x-lg"></i></button>' +
                '<div class="t-progress" style="width:100%;"></div>';
            container.appendChild(toast);
            requestAnimationFrame(function(){ requestAnimationFrame(function(){ toast.classList.add('show'); }); });
            var prog = toast.querySelector('.t-progress');
            prog.style.transitionDuration = duration + 'ms';
            requestAnimationFrame(function(){ requestAnimationFrame(function(){ prog.style.width = '0%'; }); });
            setTimeout(function(){
                toast.classList.replace('show','hide');
                setTimeout(function(){ toast.remove(); }, 400);
            }, duration);
        }
    </script>
    @if (TempData["ToastMessage"] != null)
    {
        var toastType = TempData["ToastType"]?.ToString() ?? "success";
        var toastTitle = TempData["ToastTitle"]?.ToString() ?? "Bildirim";
        var toastMessage = TempData["ToastMessage"]?.ToString();
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                showToast('@Html.Raw(toastType)', '@Html.Raw(toastTitle)', '@Html.Raw(toastMessage)');
            });
        </script>
    }

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        /* ========================================
           SIDEBAR TOGGLE LOGIC
        ======================================== */

        const isMobile = () => window.innerWidth < 992;

        function toggleSidebar() {
            if (isMobile()) {
                document.body.classList.toggle('sidebar-open');
            } else {
                document.body.classList.toggle('sidebar-collapsed');
                // Persist preference
                const isCollapsed = document.body.classList.contains('sidebar-collapsed');
                localStorage.setItem('sidebarCollapsed', isCollapsed);
            }
        }

        function closeSidebar() {
            document.body.classList.remove('sidebar-open');
        }

        // Restore sidebar state on desktop
        document.addEventListener('DOMContentLoaded', () => {
            if (!isMobile()) {
                const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
                if (isCollapsed) {
                    document.body.classList.add('sidebar-collapsed');
                }
            }
        });

        // Handle resize
        window.addEventListener('resize', () => {
            if (!isMobile()) {
                document.body.classList.remove('sidebar-open');
            }
        });

        /* ========================================
           ACTIVE NAV LINK HIGHLIGHTING
        ======================================== */
        document.querySelectorAll('#sidebar .nav-link').forEach(link => {
            link.addEventListener('click', function () {
                document.querySelectorAll('#sidebar .nav-link').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
