@using DatabaseMastery.TransportMongoDb.Dtos.ShipmentDtos
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap');

    :root {
        --primary: #0A4D68;
        --primary-light: #05668D;
        --secondary: #FDB022;
        --accent: #088395;
        --success: #16a34a;
        --danger: #dc2626;
        --warning: #f59e0b;
        --info: #3b82f6;
        --purple: #8b5cf6;
        --dark: #1e293b;
        --light: #f8fafc;
        --border: #e2e8f0;
        --card-bg: #ffffff;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins', sans-serif;
        background: var(--light);
        color: var(--dark);
    }

    .dashboard-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 40px 32px;
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ===== HEADER ===== */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
        gap: 24px;
        flex-wrap: wrap;
    }

    .header-left {
        flex: 1;
        min-width: 300px;
    }

    .welcome-text {
        font-size: 14px;
        color: #64748b;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .dashboard-title {
        font-size: 32px;
        font-weight: 800;
        color: var(--dark);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .title-icon {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 26px;
    }

    .dashboard-subtitle {
        font-size: 15px;
        color: #64748b;
        margin-top: 6px;
    }

    .header-right {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .header-date {
        background: white;
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 600;
        color: var(--dark);
    }

    .header-date i {
        color: var(--primary);
        font-size: 18px;
    }

    .btn-refresh {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        border: 1.5px solid var(--border);
        background: white;
        color: var(--dark);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-refresh:hover {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
        transform: rotate(180deg);
    }

    /* ===== MAIN STAT CARDS ===== */
    .main-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 28px;
        animation: slideUp 0.5s ease-out 0.1s both;
    }

    .main-stat-card {
        background: white;
        border-radius: 16px;
        padding: 28px;
        border: 1px solid var(--border);
        position: relative;
        overflow: hidden;
        transition: all 0.3s;
    }

    .main-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    }

    .main-stat-card::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
    }

    .main-stat-card.shipment::after { background: linear-gradient(90deg, var(--primary), var(--accent)); }
    .main-stat-card.delivered::after { background: linear-gradient(90deg, var(--success), #22c55e); }
    .main-stat-card.city::after { background: linear-gradient(90deg, var(--warning), #fbbf24); }

    .main-stat-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 18px;
    }

    .main-stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
    }

    .main-stat-card.shipment .main-stat-icon {
        background: linear-gradient(135deg, rgba(10,77,104,0.1), rgba(8,131,149,0.08));
        color: var(--primary);
    }

    .main-stat-card.delivered .main-stat-icon {
        background: linear-gradient(135deg, rgba(22,163,74,0.1), rgba(34,197,94,0.08));
        color: var(--success);
    }

    .main-stat-card.city .main-stat-icon {
        background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(251,191,36,0.08));
        color: var(--warning);
    }

    .main-stat-label {
        font-size: 13px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .main-stat-value {
        font-size: 40px;
        font-weight: 800;
        color: var(--dark);
        font-family: 'JetBrains Mono', monospace;
        line-height: 1.1;
    }

    .main-stat-desc {
        font-size: 13px;
        color: #94a3b8;
        margin-top: 4px;
    }

    /* ===== CONTENT STAT CARDS ===== */
    .content-stats {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 16px;
        margin-bottom: 28px;
        animation: slideUp 0.5s ease-out 0.2s both;
    }

    .content-stat-card {
        background: white;
        border-radius: 14px;
        padding: 22px 18px;
        border: 1px solid var(--border);
        text-align: center;
        transition: all 0.3s;
        cursor: pointer;
        text-decoration: none;
        display: block;
    }

    .content-stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.06);
        border-color: var(--primary);
    }

    .content-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin: 0 auto 12px;
    }

    .content-stat-card:nth-child(1) .content-icon { background: rgba(139,92,246,0.1); color: var(--purple); }
    .content-stat-card:nth-child(2) .content-icon { background: rgba(59,130,246,0.1); color: var(--info); }
    .content-stat-card:nth-child(3) .content-icon { background: rgba(245,158,11,0.1); color: var(--warning); }
    .content-stat-card:nth-child(4) .content-icon { background: rgba(22,163,74,0.1); color: var(--success); }
    .content-stat-card:nth-child(5) .content-icon { background: rgba(220,38,38,0.1); color: var(--danger); }
    .content-stat-card:nth-child(6) .content-icon { background: rgba(10,77,104,0.1); color: var(--primary); }

    .content-stat-value {
        font-size: 26px;
        font-weight: 800;
        color: var(--dark);
        font-family: 'JetBrains Mono', monospace;
        margin-bottom: 4px;
    }

    .content-stat-label {
        font-size: 12px;
        font-weight: 600;
        color: #64748b;
    }

    /* ===== BOTTOM GRID ===== */
    .bottom-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
        animation: slideUp 0.5s ease-out 0.3s both;
    }

    .card-panel {
        background: white;
        border-radius: 16px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 28px 20px;
        border-bottom: 1px solid var(--border);
    }

    .card-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--dark);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .card-title i {
        color: var(--primary);
        font-size: 20px;
    }

    .card-link {
        font-size: 13px;
        font-weight: 600;
        color: var(--primary);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
    }

    .card-link:hover {
        color: var(--accent);
        gap: 8px;
    }

    /* ===== SHIPMENTS TABLE ===== */
    .shipments-table {
        width: 100%;
        border-collapse: collapse;
    }

    .shipments-table th {
        padding: 14px 28px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: var(--light);
    }

    .shipments-table td {
        padding: 16px 28px;
        font-size: 14px;
        color: var(--dark);
        border-bottom: 1px solid var(--border);
    }

    .shipments-table tbody tr {
        transition: all 0.2s;
    }

    .shipments-table tbody tr:last-child td {
        border-bottom: none;
    }

    .shipments-table tbody tr:hover {
        background: var(--light);
    }

    .tracking-num {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 700;
        font-size: 13px;
        color: var(--primary);
    }

    .sender-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .sender-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 13px;
    }

    .sender-name {
        font-weight: 600;
        font-size: 13px;
    }

    .route-info {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
    }

    .route-info i {
        color: var(--accent);
        font-size: 14px;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-badge.received { background: rgba(139,92,246,0.1); color: #8b5cf6; }
    .status-badge.transit { background: rgba(59,130,246,0.1); color: #3b82f6; }
    .status-badge.delivery { background: rgba(245,158,11,0.1); color: #f59e0b; }
    .status-badge.delivered { background: rgba(22,163,74,0.1); color: #16a34a; }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    /* ===== QUICK ACTIONS ===== */
    .quick-actions-list {
        padding: 8px 0;
    }

    .quick-action-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 28px;
        text-decoration: none;
        transition: all 0.2s;
        border-bottom: 1px solid var(--border);
    }

    .quick-action-item:last-child {
        border-bottom: none;
    }

    .quick-action-item:hover {
        background: var(--light);
        padding-left: 32px;
    }

    .quick-action-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .quick-action-item:nth-child(1) .quick-action-icon { background: linear-gradient(135deg, var(--primary), var(--accent)); color: white; }
    .quick-action-item:nth-child(2) .quick-action-icon { background: linear-gradient(135deg, var(--success), #22c55e); color: white; }
    .quick-action-item:nth-child(3) .quick-action-icon { background: linear-gradient(135deg, var(--warning), #fbbf24); color: white; }
    .quick-action-item:nth-child(4) .quick-action-icon { background: linear-gradient(135deg, var(--info), #60a5fa); color: white; }
    .quick-action-item:nth-child(5) .quick-action-icon { background: linear-gradient(135deg, var(--purple), #a78bfa); color: white; }
    .quick-action-item:nth-child(6) .quick-action-icon { background: linear-gradient(135deg, var(--danger), #f87171); color: white; }

    .quick-action-text {
        flex: 1;
    }

    .quick-action-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 2px;
    }

    .quick-action-desc {
        font-size: 12px;
        color: #94a3b8;
    }

    .quick-action-arrow {
        color: #cbd5e1;
        font-size: 16px;
        transition: all 0.2s;
    }

    .quick-action-item:hover .quick-action-arrow {
        color: var(--primary);
        transform: translateX(4px);
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 1400px) {
        .content-stats {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 1200px) {
        .bottom-grid {
            grid-template-columns: 1fr;
        }
        .main-stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .dashboard-container {
            padding: 24px 16px;
        }
        .dashboard-header {
            flex-direction: column;
        }
        .dashboard-title {
            font-size: 24px;
        }
        .main-stats {
            grid-template-columns: 1fr;
        }
        .content-stats {
            grid-template-columns: repeat(2, 1fr);
        }
        .shipments-table {
            min-width: 700px;
        }
    }
</style>

<div class="dashboard-container">

    <!-- ===== HEADER ===== -->
    <div class="dashboard-header">
        <div class="header-left">
            <p class="welcome-text">Hoş Geldiniz 👋</p>
            <h1 class="dashboard-title">
                <div class="title-icon">
                    <i class="bi bi-speedometer2"></i>
                </div>
                Yönetim Paneli
            </h1>
            <p class="dashboard-subtitle">Sitenize ait tüm verileri bu panelden takip edebilirsiniz</p>
        </div>
        <div class="header-right">
            <div class="header-date">
                <i class="bi bi-calendar3"></i>
                <span id="currentDate"></span>
            </div>
            <button class="btn-refresh" onclick="location.reload()" title="Yenile">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- ===== MAIN STATS (Kargo) ===== -->
    <div class="main-stats">
        <div class="main-stat-card shipment">
            <div class="main-stat-top">
                <div>
                    <div class="main-stat-label">Toplam Kargo</div>
                    <div class="main-stat-value">@ViewBag.TotalShipment</div>
                    <div class="main-stat-desc">Sistemdeki tüm gönderiler</div>
                </div>
                <div class="main-stat-icon">
                    <i class="bi bi-box-seam-fill"></i>
                </div>
            </div>
        </div>

        <div class="main-stat-card delivered">
            <div class="main-stat-top">
                <div>
                    <div class="main-stat-label">Teslim Edilen</div>
                    <div class="main-stat-value">@ViewBag.DeliveredShipment</div>
                    <div class="main-stat-desc">Başarıyla teslim edildi</div>
                </div>
                <div class="main-stat-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
        </div>

        <div class="main-stat-card city">
            <div class="main-stat-top">
                <div>
                    <div class="main-stat-label">Hizmet Verilen Şehir</div>
                    <div class="main-stat-value">@ViewBag.CityCount</div>
                    <div class="main-stat-desc">Farklı varış noktası</div>
                </div>
                <div class="main-stat-icon">
                    <i class="bi bi-geo-alt-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== CONTENT STATS ===== -->
    <div class="content-stats">
        <a href="/Slider/SliderList" class="content-stat-card">
            <div class="content-icon">
                <i class="bi bi-images"></i>
            </div>
            <div class="content-stat-value">@ViewBag.SliderCount</div>
            <div class="content-stat-label">Slider</div>
        </a>
        <a href="/Brand/BrandList" class="content-stat-card">
            <div class="content-icon">
                <i class="bi bi-building"></i>
            </div>
            <div class="content-stat-value">@ViewBag.BrandCount</div>
            <div class="content-stat-label">Marka</div>
        </a>
        <a href="/Offer/OfferList" class="content-stat-card">
            <div class="content-icon">
                <i class="bi bi-gift"></i>
            </div>
            <div class="content-stat-value">@ViewBag.OfferCount</div>
            <div class="content-stat-label">Hizmet</div>
        </a>
        <a href="/Testimonial/TestimonialList" class="content-stat-card">
            <div class="content-icon">
                <i class="bi bi-chat-quote-fill"></i>
            </div>
            <div class="content-stat-value">@ViewBag.TestimonialCount</div>
            <div class="content-stat-label">Referans</div>
        </a>
        <a href="/Project/ProjectList" class="content-stat-card">
            <div class="content-icon">
                <i class="bi bi-folder-fill"></i>
            </div>
            <div class="content-stat-value">@ViewBag.ProjectCount</div>
            <div class="content-stat-label">Proje</div>
        </a>
        <a href="/Question/QuestionList" class="content-stat-card">
            <div class="content-icon">
                <i class="bi bi-question-circle-fill"></i>
            </div>
            <div class="content-stat-value">@ViewBag.QuestionCount</div>
            <div class="content-stat-label">SSS</div>
        </a>
    </div>

    <!-- ===== BOTTOM: Table + Quick Actions ===== -->
    <div class="bottom-grid">

        <!-- Recent Shipments Table -->
        <div class="card-panel">
            <div class="card-header">
                <div class="card-title">
                    <i class="bi bi-clock-history"></i>
                    Son Gönderiler
                </div>
                <a href="/Shipment/ShipmentList" class="card-link">
                    Tümünü Gör <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            @{
                var recentShipments = ViewBag.RecentShipments as List<ResultShipmentDto>;
            }
            @if (recentShipments != null && recentShipments.Any())
            {
                <div style="overflow-x: auto;">
                    <table class="shipments-table">
                        <thead>
                            <tr>
                                <th>Takip No</th>
                                <th>Gönderici</th>
                                <th>Rota</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var shipment in recentShipments)
                            {
                                <tr>
                                    <td>
                                        <span class="tracking-num">@shipment.TrackingNumber</span>
                                    </td>
                                    <td>
                                        <div class="sender-info">
                                            <div class="sender-avatar">
                                                @shipment.SenderName.Substring(0, 1).ToUpper()
                                            </div>
                                            <span class="sender-name">@shipment.SenderName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="route-info">
                                            <span>@shipment.OriginCity</span>
                                            <i class="bi bi-arrow-right-short"></i>
                                            <span>@shipment.DestinationCity</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(shipment.CurrentStatus)">
                                            <span class="status-dot"></span>
                                            @shipment.CurrentStatus
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 48px 24px; color: #94a3b8;">
                    <i class="bi bi-inbox" style="font-size: 40px; display: block; margin-bottom: 12px;"></i>
                    <p style="font-weight: 600;">Henüz gönderi bulunmuyor</p>
                </div>
            }
        </div>

        <!-- Quick Actions -->
        <div class="card-panel">
            <div class="card-header">
                <div class="card-title">
                    <i class="bi bi-lightning-fill"></i>
                    Hızlı İşlemler
                </div>
            </div>
            <div class="quick-actions-list">
                <a href="/Shipment/CreateShipment" class="quick-action-item">
                    <div class="quick-action-icon">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <div class="quick-action-text">
                        <div class="quick-action-title">Yeni Kargo Ekle</div>
                        <div class="quick-action-desc">Yeni bir gönderi oluştur</div>
                    </div>
                    <i class="bi bi-chevron-right quick-action-arrow"></i>
                </a>
                <a href="/Slider/CreateSlider" class="quick-action-item">
                    <div class="quick-action-icon">
                        <i class="bi bi-images"></i>
                    </div>
                    <div class="quick-action-text">
                        <div class="quick-action-title">Slider Ekle</div>
                        <div class="quick-action-desc">Ana sayfaya slider ekle</div>
                    </div>
                    <i class="bi bi-chevron-right quick-action-arrow"></i>
                </a>
                <a href="/Brand/CreateBrand" class="quick-action-item">
                    <div class="quick-action-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="quick-action-text">
                        <div class="quick-action-title">Marka Ekle</div>
                        <div class="quick-action-desc">Yeni marka/firma ekle</div>
                    </div>
                    <i class="bi bi-chevron-right quick-action-arrow"></i>
                </a>
                <a href="/Offer/CreateOffer" class="quick-action-item">
                    <div class="quick-action-icon">
                        <i class="bi bi-gift"></i>
                    </div>
                    <div class="quick-action-text">
                        <div class="quick-action-title">Hizmet Ekle</div>
                        <div class="quick-action-desc">Yeni hizmet tanımla</div>
                    </div>
                    <i class="bi bi-chevron-right quick-action-arrow"></i>
                </a>
                <a href="/Project/CreateProject" class="quick-action-item">
                    <div class="quick-action-icon">
                        <i class="bi bi-folder-plus"></i>
                    </div>
                    <div class="quick-action-text">
                        <div class="quick-action-title">Proje Ekle</div>
                        <div class="quick-action-desc">Yeni proje paylaş</div>
                    </div>
                    <i class="bi bi-chevron-right quick-action-arrow"></i>
                </a>
                <a href="/" class="quick-action-item">
                    <div class="quick-action-icon">
                        <i class="bi bi-globe"></i>
                    </div>
                    <div class="quick-action-text">
                        <div class="quick-action-title">Siteyi Görüntüle</div>
                        <div class="quick-action-desc">Ana sayfaya git</div>
                    </div>
                    <i class="bi bi-chevron-right quick-action-arrow"></i>
                </a>
            </div>
        </div>

    </div>

</div>

@functions {
    string GetStatusClass(string status)
    {
        return status switch
        {
            "Gönderi Alındı" => "received",
            "Transfer Merkezinde" => "transit",
            "Yolda" => "transit",
            "Dağıtımda" => "delivery",
            "Teslim Edildi" => "delivered",
            _ => "transit"
        };
    }
}

<script>
    // Tarih gösterimi
    const now = new Date();
    const options = { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' };
    document.getElementById('currentDate').textContent = now.toLocaleDateString('tr-TR', options);
</script>
